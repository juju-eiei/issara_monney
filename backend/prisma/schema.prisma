generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Owner {
  id           String @id @default(uuid())
  username     String @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id              String   @id @default(uuid())
  phone           String   @unique
  pinHash         String
  name            String?
  totalItemsSpent Float    @default(0) // Lifetime raw points or money spent
  rewardBalance   Int      @default(0) // Available rewards to redeem
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  transactions    Transaction[]
  redemptions     Redemption[]
}

model Transaction {
  id         String   @id @default(uuid())
  customerId String
  amount     Float
  type       String   // "PURCHASE" 
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
}

model Redemption {
  id           String   @id @default(uuid())
  customerId   String
  rewardsUsed  Int
  cashReceived Float
  createdAt    DateTime @default(now())

  customer     Customer @relation(fields: [customerId], references: [id])
}
